{
  "productName": "APIPup",
  "version": "0.1.0",
  "identifier": "com.apipup.app",
  "build": {
    "beforeDevCommand": "pnpm --filter apipup-ui dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm --filter apipup-ui build",
    "frontendDist": "../ui/build"
  },
  "app": {
    "windows": [
      {
        "title": "APIPup",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
